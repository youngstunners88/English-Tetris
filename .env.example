# English Learning Tetris - Environment Variables

# Optional: ElevenLabs API Key for AI voice features
# Get your API key at: https://elevenlabs.io/app/sign-up
# Without this key, the game will use browser's native speech synthesis
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional: Custom ElevenLabs Voice ID
# Default uses a natural-sounding English voice
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Development settings
NEXT_TELEMETRY_DISABLED=1
